# =====================================================
# 🔑 VARIABLES DE ENTORNO - SEEDANCE 2.0 STUDIO
# =====================================================

# ============================================
# PRODUCCIÓN: URL DEL BACKEND
# ============================================
# VITE_API_URL: URL donde está desplegado el servidor Express (server.ts)
# 
# DESARROLLO (localhost):
#   - Dejar vacío o comentado
#   - El sistema automáticamente usa http://localhost:3000
#
# PRODUCCIÓN:
#   - Si frontend y backend están en el MISMO dominio → Dejar vacío
#   - Si backend está en URL diferente → Especificar la URL completa
#
# Ejemplos:
#   VITE_API_URL=https://api-seedance.tu-dominio.com
#   VITE_API_URL=https://tu-backend.vercel.app
#   VITE_API_URL=https://seedance-server-xyz123.onrender.com
#
# ⚠️ CRÍTICO: Sin esto, el frontend no puede comunicarse con el backend en producción
VITE_API_URL=

# ============================================
# PROXY DE SALIDA (OPCIONAL - CAMBIO DE IP)
# ============================================
# Si la IP del servidor es bloqueada por videogenapi.com,
# configura un proxy para cambiar la IP de salida.
# Servicios recomendados: BrightData, Oxylabs, Webshare.io
# OUTBOUND_PROXY_URL=http://user:pass@proxy.example.com:8080

# ============================================
# API KEYS (OBLIGATORIAS)
# ============================================
# Multi-Key Load Balancing: El sistema soporta hasta 10 API keys
# - Las keys se rotan automáticamente cuando una alcanza el límite
# - Cada key permite 10 videos/día
# - Total diario = 10 videos × número de keys
#
# Configuración actual: 3 keys — Key 1 = cuenta fresca (digitalpersistencia@gmail.com)
VIDEOGEN_API_KEY_1=lannetech_bd09d6619cf9a0bd00b82e93bfd99fd1d1da16df9a20670482bb4f792d333fbf
VIDEOGEN_API_KEY_2=lannetech_9e52baad0ac50fab82dd58dbf1ecf01348c73b3ddcc7ef1627a42e49c525d4d6
VIDEOGEN_API_KEY_3=lannetech_4d5fc5ef833b1cf9a26408e4302dc4c74d759689ac4e366fb118e341e6a4e337

# Para agregar más keys (opcional):
# VIDEOGEN_API_KEY_4=lannetech_...
# ... hasta VIDEOGEN_API_KEY_10

# ============================================
# SUPABASE (OBLIGATORIO PARA SUBIR IMÁGENES)
